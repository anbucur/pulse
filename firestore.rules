rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }
    function uidUnchanged() { return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid; }
    function uidNotModified() { return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid; }
    function hasOnlyAllowedFields(fields) { return request.resource.data.keys().hasOnly(fields); }
    
    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'role', 'isVerified']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.role in ['user', 'admin'] &&
             data.isVerified is bool;
    }

    function isValidPublicProfile(data) {
      return hasOnlyAllowedFields(['uid', 'displayName', 'photoURL', 'age', 'height', 'weight', 'sexualRole', 'tribes', 'bio', 'tags', 'intent', 'lat', 'lng', 'livePulseExpiresAt', 'lastActive', 'isGhostMode', 'broadcast', 'broadcastExpiresAt', 'isVerified']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.displayName is string && data.displayName.size() <= 50 &&
             data.age is number && data.age >= 18 &&
             data.intent is string && data.intent.size() <= 50 &&
             data.lat is number && data.lng is number &&
             data.lastActive is number &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500)) &&
             (!('height' in data) || data.height is number) &&
             (!('weight' in data) || data.weight is number) &&
             (!('sexualRole' in data) || (data.sexualRole is string && data.sexualRole.size() <= 20)) &&
             (!('tribes' in data) || (data.tribes is list && data.tribes.size() <= 10)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 500)) &&
             (!('tags' in data) || (data.tags is list && data.tags.size() <= 20)) &&
             (!('livePulseExpiresAt' in data) || data.livePulseExpiresAt == null || data.livePulseExpiresAt is number) &&
             (!('isGhostMode' in data) || data.isGhostMode is bool) &&
             (!('broadcast' in data) || data.broadcast == null || (data.broadcast is string && data.broadcast.size() <= 200)) &&
             (!('broadcastExpiresAt' in data) || data.broadcastExpiresAt == null || data.broadcastExpiresAt is number) &&
             (!('isVerified' in data) || data.isVerified is bool);
    }

    function isValidChat(data) {
      return hasOnlyAllowedFields(['participants', 'lastMessage', 'updatedAt', 'unreadCount']) &&
             data.participants is list && data.participants.size() == 2 &&
             data.participants[0] is string && data.participants[1] is string &&
             data.updatedAt is number &&
             (!('lastMessage' in data) || (data.lastMessage is string && data.lastMessage.size() <= 1000)) &&
             (!('unreadCount' in data) || data.unreadCount is map);
    }

    function isValidMessage(data) {
      return hasOnlyAllowedFields(['senderId', 'text', 'timestamp', 'isRead', 'mediaUrl', 'isNSFW', 'isViewOnce', 'viewedAt']) &&
             data.senderId is string &&
             data.timestamp is number &&
             data.isRead is bool &&
             (!('text' in data) || (data.text is string && data.text.size() <= 1000)) &&
             (!('mediaUrl' in data) || (data.mediaUrl is string && data.mediaUrl.size() <= 500)) &&
             (!('isNSFW' in data) || data.isNSFW is bool) &&
             (!('isViewOnce' in data) || data.isViewOnce is bool) &&
             (!('viewedAt' in data) || data.viewedAt == null || data.viewedAt is number);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && uidUnchanged();
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && uidNotModified();
      allow delete: if isOwner(userId);
    }

    match /public_profiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidPublicProfile(request.resource.data) && uidUnchanged();
      allow update: if isOwner(userId) && isValidPublicProfile(request.resource.data) && uidNotModified();
      allow delete: if isOwner(userId);
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && isValidChat(request.resource.data) && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && isValidChat(request.resource.data) && request.auth.uid in resource.data.participants && request.auth.uid in request.resource.data.participants;
      allow delete: if isAuthenticated() && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated() && isValidMessage(request.resource.data) && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants && request.resource.data.senderId == request.auth.uid;
        allow update: if isAuthenticated() && isValidMessage(request.resource.data) && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants && request.resource.data.senderId == resource.data.senderId;
        allow delete: if isAuthenticated() && request.auth.uid == resource.data.senderId;
      }
    }
  }
}
