{
  "entities": {
    "User": {
      "title": "User",
      "description": "Private user data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "isVerified": { "type": "boolean" }
      },
      "required": ["uid", "email", "role", "isVerified"]
    },
    "PublicProfile": {
      "title": "PublicProfile",
      "description": "Public profile data for the grid.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "age": { "type": "number" },
        "height": { "type": "number" },
        "weight": { "type": "number" },
        "sexualRole": { "type": "string" },
        "tribes": { "type": "array" },
        "bio": { "type": "string" },
        "tags": { "type": "array" },
        "intent": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "livePulseExpiresAt": { "type": "number" },
        "lastActive": { "type": "number" }
      },
      "required": ["uid", "displayName", "age", "intent", "lat", "lng", "lastActive"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A chat conversation.",
      "type": "object",
      "properties": {
        "participants": { "type": "array" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "number" }
      },
      "required": ["participants", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A message in a chat.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "number" },
        "isRead": { "type": "boolean" },
        "mediaUrl": { "type": "string" },
        "isNSFW": { "type": "boolean" }
      },
      "required": ["senderId", "timestamp", "isRead"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": { "$ref": "User" }, "description": "Private user data." },
    "/public_profiles/{uid}": { "schema": { "$ref": "PublicProfile" }, "description": "Public profile data." },
    "/chats/{chatId}": { "schema": { "$ref": "Chat" }, "description": "Chat conversations." },
    "/chats/{chatId}/messages/{messageId}": { "schema": { "$ref": "Message" }, "description": "Chat messages." }
  }
}
