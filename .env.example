# GEMINI_API_KEY: Required for Gemini AI API calls (server-side only — never exposed to client).
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# VITE_FCM_VAPID_KEY: Firebase Cloud Messaging VAPID key for push notifications.
# Obtain from Firebase Console > Project Settings > Cloud Messaging > Web Push certificates.
VITE_FCM_VAPID_KEY="MY_FCM_VAPID_KEY"

# GOOGLE_APPLICATION_CREDENTIALS: Path to Firebase service account key JSON (local dev only).
# On Cloud Run, Workload Identity is used automatically via applicationDefault().
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account-key.json"

# ANTHROPIC_API_KEY: Required for the Anthropic Token Plan (claude-3-5-haiku).
# Obtain from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"

# MINIMAX_API_KEY: Required for the Minimax Token Plan (MiniMax-Text-01).
# Obtain from https://platform.minimax.io
MINIMAX_API_KEY="MY_MINIMAX_API_KEY"

# ZAI_API_KEY: Required for the z.ai Coding Plan (z1-preview).
# Obtain from https://z.ai
ZAI_API_KEY="MY_ZAI_API_KEY"
