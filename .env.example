# Database
DATABASE_URL=postgresql://pulse:YOUR_DB_PASSWORD@localhost:5432/pulse

# Redis
REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=YOUR_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=YOUR_MINIO_SECRET_KEY_MIN_16_CHARS
MINIO_BUCKET=pulse

# Meilisearch
MEILISEARCH_ENDPOINT=http://localhost:7700
MEILISEARCH_API_KEY=YOUR_MEILISEARCH_MASTER_KEY

# JWT - IMPORTANT: Use a strong, random secret at least 32 characters long
# Generate with: openssl rand -base64 32
JWT_SECRET=YOUR_JWT_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# AI
GEMINI_API_KEY=your_gemini_api_key

# Web Push (VAPID)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
