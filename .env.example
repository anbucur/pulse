# Database
DATABASE_URL=postgresql://pulse:pulse_password_change_in_production@localhost:5432/pulse

# Redis
REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_change_in_production
MINIO_BUCKET=pulse

# Meilisearch
MEILISEARCH_ENDPOINT=http://localhost:7700
MEILISEARCH_API_KEY=meilisearch_master_key_change_in_production

# JWT
JWT_SECRET=your_jwt_secret_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# AI
GEMINI_API_KEY=your_gemini_api_key

# Web Push (VAPID)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*
